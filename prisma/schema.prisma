generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id           String        @id @default(cuid())
  name         String
  description  String
  price        Float
  duration     Int
  image        String?
  category     String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  bookingItems BookingService[]

  @@map("services")
}

model Stylist {
  id        String    @id @default(cuid())
  name      String
  bio       String
  image     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  bookings  Booking[]

  @@map("stylists")
}

model Booking {
  id                  String            @id @default(cuid())
  customerName        String            @map("customer_name")
  customerEmail       String            @map("customer_email")
  customerPhone       String            @map("customer_phone")
  stylistId           String            @map("stylist_id")
  date                DateTime
  time                String
  status              String            @default("pending")
  notes               String?
  userId              String?           @map("user_id")
  couponCode          String?           @map("coupon_code")
  couponId            String?           @map("coupon_id")
  discountPercent     Int?              @map("discount_percent")
  discountAmount      Float?            @default(0) @map("discount_amount")
  totalBeforeDiscount Float?            @default(0) @map("total_before_discount")
  finalAmount         Float?            @default(0) @map("final_amount")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  stylist             Stylist           @relation(fields: [stylistId], references: [id])
  bookingItems        BookingService[]
  coupon              CouponCode?       @relation(fields: [couponId], references: [id])
  user                User?             @relation(fields: [userId], references: [id])

  @@map("bookings")
}

model BookingService {
  id             String   @id @default(cuid())
  bookingId      String   @map("booking_id")
  serviceId      String   @map("service_id")
  serviceName    String   @map("service_name")
  servicePrice   Float    @map("service_price")
  discountedPrice Float?  @map("discounted_price")
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service        Service  @relation(fields: [serviceId], references: [id])

  @@map("booking_services")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  category  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_images")
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  image           String?
  author          String    @default("Admin")
  published       Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model SeoMeta {
  id          String   @id @default(cuid())
  page        String   @unique
  title       String?
  description String?
  keywords    String?
  ogImage     String?
  schemaJson  String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("seo_meta")
}

model User {
  id             String              @id @default(cuid())
  fullName       String              @map("full_name")
  email          String              @unique
  mobile         String?
  address        String?
  password       String
  role           String              @default("customer")
  totalTimeSpent Int                 @default(0) @map("total_time_spent")
  lastActiveAt   DateTime?           @map("last_active_at")
  lastLoginAt    DateTime?           @map("last_login_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  spinHistory    SpinHistory[]
  dailySpinUsage DailySpinUsage[]
  sessions       UserSession[]
  coupons        UserCoupon[]
  bookings       Booking[]
  eventBookings  EventBooking[]
  notifications  Notification[]

  @@map("users")
}

model CouponCode {
  id              String          @id @default(cuid())
  code            String          @unique
  title           String
  description     String?
  couponType      String          @default("public") @map("coupon_type")  // "public" | "private" | "spin" | "referral"
  discountType    String          @default("percentage") @map("discount_type")  // "percentage" | "fixed" | "full_service"
  discountValue   Float           @default(0) @map("discount_value")
  discountPercent Int?            @map("discount_percent")
  category        String?         // "hair" | "nails" | "skincare" | "makeup" | "massage" – null = all
  allowedServices String[]        @map("allowed_services")  // service IDs or empty = all
  isPublic        Boolean         @default(false) @map("is_public")
  isActive        Boolean         @default(true) @map("is_active")
  minimumAmount   Float?          @default(0) @map("minimum_amount")
  maxUsage        Int             @default(0) @map("max_usage")  // 0 = unlimited
  usedCount       Int             @default(0) @map("used_count")
  expiryDate      DateTime?       @map("expiry_date")
  createdBy       String?         @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  userCoupons     UserCoupon[]
  bookings        Booking[]
  usage           CouponUsage[]

  @@map("coupon_codes")
}

model UserCoupon {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  couponId    String      @map("coupon_id")
  code        String      @unique  // the actual code user enters (e.g. NAIL5-K8S2P)
  isRedeemed  Boolean     @default(false) @map("is_redeemed")
  redeemedAt  DateTime?   @map("redeemed_at")
  assignedAt  DateTime    @default(now()) @map("assigned_at")
  user        User        @relation(fields: [userId], references: [id])
  coupon      CouponCode  @relation(fields: [couponId], references: [id])

  @@map("user_coupons")
}

model CouponUsage {
  id          String      @id @default(cuid())
  couponId    String      @map("coupon_id")
  userId      String      @map("user_id")
  bookingId   String      @map("booking_id")
  discountAmount Float    @default(0) @map("discount_amount")
  createdAt   DateTime    @default(now()) @map("created_at")
  coupon      CouponCode  @relation(fields: [couponId], references: [id])

  @@map("coupon_usage")
}

model SpinOffer {
  id          String        @id @default(cuid())
  title       String
  description String?
  probability Float
  rewardType  String        @map("reward_type")
  couponCode  String?       @map("coupon_code")
  image       String?
  isActive    Boolean       @default(true) @map("is_active")
  color       String?
  category    String?
  discountPercent Int?          @default(0) @map("discount_percent")
  discountValue   Float?        @default(0) @map("discount_value")
  discountType    String?       @default("percentage") @map("discount_type")
  expiryDate      DateTime?     @map("expiry_date")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  spinHistory     SpinHistory[]

  @@map("spin_offers")
}

model SpinHistory {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  offerId    String?    @map("offer_id")
  reward     String
  couponCode String?    @map("coupon_code")
  status     String     @default("active")  // active | redeemed | expired | skipped
  expiryDate DateTime?  @map("expiry_date")
  discountPercent Int?  @default(0) @map("discount_percent")
  discountValue   Float? @default(0) @map("discount_value")
  discountType    String? @default("percentage") @map("discount_type")
  category    String?
  createdAt   DateTime   @default(now()) @map("created_at")
  user        User       @relation(fields: [userId], references: [id])
  offer       SpinOffer? @relation(fields: [offerId], references: [id])

  @@map("spin_history")
}

model DailySpinUsage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  spinsUsed Int      @default(0) @map("spins_used")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("daily_spin_usage")
}

model SpinConfig {
  id                    String   @id @default(cuid())
  dailySpinLimit        Int      @default(10) @map("daily_spin_limit")
  weeklyClaimPeriodDays Int      @default(7) @map("weekly_claim_period_days")
  antiSpamCooldownMs    Int      @default(3000) @map("anti_spam_cooldown_ms")
  stalePendingMinutes   Int      @default(10) @map("stale_pending_minutes")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("spin_config")
}

model UserSession {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  sessionStart   DateTime  @map("session_start")
  sessionEnd     DateTime? @map("session_end")
  activeDuration Int?      @default(0) @map("active_duration")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model PaymentConfig {
  id           String   @id @default(cuid())
  bankName     String?  @map("bank_name")
  bankAccount  String?  @map("bank_account")
  bankHolder   String?  @map("bank_holder")
  esewaNumber  String?  @map("esewa_number")
  khaltiNumber String?  @map("khalti_number")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("payment_config")
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String?
  image         String?
  startDate     DateTime      @map("start_date")
  endDate       DateTime      @map("end_date")
  capacity      Int           @default(0)
  price         Float         @default(0)
  category      String?
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  bookings      EventBooking[]

  @@map("events")
}

model EventBooking {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  customerName  String  @map("customer_name")
  customerEmail String  @map("customer_email")
  customerPhone String  @map("customer_phone")
  status    String   @default("confirmed")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("event_bookings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  role      String?  @default("customer")
  title     String
  message   String
  type      String   @default("info")
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("notifications")
}
